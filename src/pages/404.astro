---
import Layout from '../layouts/Layout.astro';
import { t } from '../data/translations.js';
---

<Layout title="404 — Page not found" description="This page doesn't exist.">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: #1e2228;
      color: #dde1e7;
      font-family: 'Piazzolla', serif;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
    }

    .container {
      padding: 2rem;
    }

    h1 {
      font-size: 4rem;
      color: #fff;
      margin-bottom: 0.5rem;
    }

    p {
      font-size: 1.2rem;
      color: #ccc;
      margin-bottom: 2rem;
    }

    a {
      color: #6aaeee;
      text-decoration: underline;
      font-size: 1.1rem;
    }

    a:hover {
      color: #fff;
    }
  </style>

  <main id="main">
    <div class="container">
      <h1>404</h1>
      <p id="not-found-msg"></p>
      <a id="not-found-link" href="/"></a>
    </div>
  </main>

  <script define:vars={{ strings: { en: { msg: t.en.notFound, home: t.en.goHome }, no: { msg: t.no.notFound, home: t.no.goHome } } }}>
    const isNo = window.location.pathname.startsWith('/no/') || window.location.pathname === '/no';
    const tr = isNo ? strings.no : strings.en;
    document.getElementById('not-found-msg').textContent = tr.msg;
    const link = document.getElementById('not-found-link');
    link.textContent = tr.home;
    link.href = isNo ? '/no' : '/';
  </script>
</Layout>
