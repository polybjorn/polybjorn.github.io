---
import Layout from '../layouts/Layout.astro';
import { t } from '../data/translations.js';
import { cv } from '../data/cv.js';
import { ArrowUp, ArrowLeft, FileText } from 'lucide-astro';

const lang = 'en';
const tr = t[lang];
---

<Layout lang={lang} title="CV – Bjørn A. Andersen" description="Curriculum vitae for Bjørn A. Andersen: 3D modelling, additive manufacturing, graphic design, and 3D printing courses.">
  <link slot="head" rel="preload" as="image" href="https://res.cloudinary.com/djpkffk5u/image/upload/v1772287930/profile-img_pr1q8o.png" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: #1e2228;
      color: #eef0f3;
      font-family: 'Piazzolla', serif;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .cv-wrap {
      max-width: 720px;
      width: 100%;
      padding: 4rem 2rem 4rem;
    }

    .cv-header {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      margin-bottom: 2rem;
      gap: 1rem;
    }

    .cv-avatar {
      width: 130px;
      height: 130px;
      border-radius: 50%;
      object-fit: cover;
    }

    .back {
      display: inline-block;
      color: #ccc;
      text-decoration: none;
      font-size: 0.85rem;
      letter-spacing: 0.05em;
      transition: color 0.2s;
    }
    .back:hover { color: #fff; }

    .back-home {
      position: fixed;
      top: calc(1rem - 4px);
      left: 1rem;
      color: #ccc;
      text-decoration: none;
      z-index: 100;
      opacity: 0.75;
      transition: opacity 0.3s, transform 0.3s;
      line-height: 1;
    }
    .back-home:hover { opacity: 1; color: #fff; }
    .back-home.hidden {
      opacity: 0;
      pointer-events: none;
      transform: translateY(-0.5rem);
    }

    .scroll-top {
      position: fixed;
      bottom: 1rem;
      left: 50%;
      transform: translateX(-50%) translateY(0.5rem);
      color: #ccc;
      text-decoration: none;
      z-index: 100;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s, transform 0.3s;
      line-height: 1;
    }
    .scroll-top.visible {
      opacity: 0.75;
      pointer-events: auto;
      transform: translateX(-50%) translateY(0);
    }
    .scroll-top:hover { opacity: 1; color: #fff; }

    h1 {
      font-family: 'Piazzolla', serif;
      font-size: 1rem;
      color: #EEF0F3;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }


    section {
      margin-bottom: 3rem;
      margin-top: 1.5rem;
    }

    h2 {
      font-family: 'Piazzolla', serif;
      font-size: 1.1rem;
      font-weight: normal;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #EEF0F3;
      margin: 0 auto 1.5rem;
      width: fit-content;
    }

    .entry {
      display: grid;
      grid-template-columns: 100px 1fr;
      gap: 0.5rem 1rem;
      margin-bottom: 1.5rem;
    }

    .period {
      color: #8a8f99;
      font-size: 0.85rem;
    }

    .entry-content .title {
      color: #fff;
      font-weight: bold;
      font-size: 1rem;
    }

    .entry-content .org {
      color: #8a8f99;
      font-size: 0.9rem;
      margin-bottom: 0.3rem;
    }

    .entry-content .desc {
      color: #dde1e7;
      font-size: 0.9rem;
      line-height: 1.6;
    }

    .entry-content .org a {
      color: #6aaeee;
      text-decoration: none;
    }

    .entry-content .org a:hover {
      text-decoration: underline;
    }

    .entry-content .org .insta-link {
      display: inline-flex;
      align-items: center;
      margin-left: 0.4rem;
      color: #c084fc;
      vertical-align: middle;
      transition: opacity 0.2s;
    }

    .entry-content .org .insta-link:hover {
      opacity: 0.8;
    }

    .entry-content .org .fb-link {
      display: inline-flex;
      align-items: center;
      margin-left: 0.4rem;
      color: #4a9edd;
      vertical-align: middle;
      transition: opacity 0.2s;
    }

    .entry-content .org .fb-link:hover {
      opacity: 0.8;
    }

    .skills-list {
      list-style: none;
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.5rem;
    }

    .skills-list li {
      background: #2a2e35;
      color: #eef0f3;
      font-size: 0.85rem;
      padding: 0.3rem 0.8rem;
      border-radius: 4px;
    }

    .software-group {
      margin-bottom: 1.5rem;
    }

    .software-group h3 {
      font-size: 0.8rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: #8a8f99;
      margin-bottom: 0.6rem;
      font-weight: normal;
      text-align: center;
    }

    .software-list {
      list-style: none;
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.5rem;
    }

    .software-list li {
      background: #2a2e35;
      color: #eef0f3;
      font-size: 0.8rem;
      padding: 0.25rem 0.7rem;
      border-radius: 4px;
    }

    .references {
      color: #ccc;
      font-size: 0.8rem;
      letter-spacing: 0.05em;
      text-align: center;
      margin-top: 0.5rem;
    }

    .cv-downloads {
      display: flex;
      gap: 0.6rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    .cv-downloads a {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      background: #2a2e35;
      color: #6aaeee;
      text-decoration: none;
      font-size: 0.8rem;
      padding: 0.35rem 0.9rem;
      border-radius: 999px;
      transition: background 0.2s, color 0.2s;
    }

    .cv-downloads a:hover {
      background: #353a42;
      color: #fff;
    }

    .cv-downloads a.secondary {
      background: none;
      color: #8a8f99;
      font-size: 0.75rem;
      padding: 0.35rem 0.5rem;
    }

    .cv-downloads a.secondary:hover {
      background: none;
      color: #ccc;
    }

    @media (max-width: 480px) {
      .entry {
        grid-template-columns: 1fr;
        gap: 0.2rem;
      }
      .period {
        font-size: 0.8rem;
      }
      .cv-wrap {
        padding: 2rem 1.5rem 3rem;
      }
    }

    @media print {
      body {
        background: #fff;
        color: #111;
      }
      .cv-wrap {
        padding: 0;
        max-width: 100%;
      }
      .back-home, .scroll-top, .skip-link { display: none; }
      h1 { color: #555; }
      h2 { color: #555; }
      .period { color: #555; }
      .entry-content .title { color: #111; }
      .entry-content .org { color: #555; }
      .entry-content .desc { color: #222; }
      .entry { break-inside: avoid; }
      section { break-inside: avoid; }
      .skills-list li, .software-list li {
        background: none;
        color: #111;
        border: 1px solid #ccc;
      }
      .software-group h3 { color: #555; }
      .references { color: #555; }
      .entry-content .org a { color: #111; text-decoration: underline; }
      .entry-content .org .insta-link,
      .entry-content .org .fb-link { display: none; }
      a[href^="http"]::after {
        content: " (" attr(href) ")";
        font-size: 0.75rem;
        color: #666;
      }
    }
  </style>

  <a class="back-home" href="/" aria-label="Back to home"><ArrowLeft size={28} strokeWidth={1.5} /></a>
  <main id="main">
  <div class="cv-wrap">
    <div class="cv-header">
      <img
        class="cv-avatar"
        src="https://res.cloudinary.com/djpkffk5u/image/upload/v1772287930/profile-img_pr1q8o.png"
        alt="Bjørn A. Andersen"
      />
      <h1>Bjørn Andreas Andersen</h1>
      <div class="cv-downloads">
        <a href="/CV-Bjorn-Andersen-EN.pdf" target="_blank" rel="noopener"><FileText size={14} /> {tr.cv_current}</a>
        <a href="/CV-Bjorn-Andersen-NO.pdf" target="_blank" rel="noopener" class="secondary"><FileText size={14} /> {tr.cv_other}</a>
      </div>
    </div>

    <section>
      <h2>{tr.experience}</h2>
      {cv.experience.map(entry => (
        <div class="entry">
          <div class="period">{entry.period}</div>
          <div class="entry-content">
            <div class="title">{entry[lang].title}</div>
            <div class="org">
              {entry.links?.website
                ? <a href={entry.links.website} target="_blank" rel="noopener">{entry[lang].org}</a>
                : entry[lang].org}
              {entry.links?.instagram && (
                <a href={entry.links.instagram} target="_blank" rel="noopener" class="insta-link" aria-label="Instagram">
                  <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
                  </svg>
                </a>
              )}
              {entry.links?.facebook && (
                <a href={entry.links.facebook} target="_blank" rel="noopener" class="fb-link" aria-label="Facebook">
                  <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                    <path fill="currentColor" stroke="none" d="M13 10h2.5l-.5 2.5H13V18h-2.5v-5.5H9V10h1.5V8.5A2.5 2.5 0 0 1 13 6h2v2.5h-1.5a.5.5 0 0 0-.5.5V10z"/>
                  </svg>
                </a>
              )}
            </div>
            <div class="desc">{entry[lang].desc}</div>
          </div>
        </div>
      ))}
    </section>

    <section>
      <h2>{tr.education}</h2>
      {cv.education.map(entry => (
        <div class="entry">
          <div class="period">{entry.period}</div>
          <div class="entry-content">
            <div class="title">{entry[lang].title}</div>
            <div class="org">{entry[lang].org}</div>
          </div>
        </div>
      ))}
    </section>

    <section>
      <h2>{tr.skills}</h2>
      <ul class="skills-list">
        {cv.skills.map(skill => (
          <li>{skill[lang]}</li>
        ))}
      </ul>
    </section>

    <section>
      <h2>{tr.software}</h2>
      {cv.software.map(cat => (
        <div class="software-group">
          <h3>{cat.category[lang]}</h3>
          <ul class="software-list">
            {cat.tools.map(item => <li>{item}</li>)}
          </ul>
        </div>
      ))}
    </section>

  </div>
  <a class="scroll-top" href="#" onclick="window.scrollTo({top:0,behavior:'smooth'});this.classList.remove('visible');return false;" aria-label="Back to top"><ArrowUp size={28} strokeWidth={1.5} /></a>
  </main>

  <script>
    import { annotate } from 'rough-notation';
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const a = annotate(entry.target, { type: 'underline', color: '#6AAEEE', strokeWidth: 2, animationDuration: 800 });
          a.show();
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('h2').forEach(el => observer.observe(el));

    const backHome = document.querySelector('.back-home');
    const scrollTop = document.querySelector('.scroll-top');
    window.addEventListener('scroll', () => {
      backHome.classList.toggle('hidden', window.scrollY > 60);
      scrollTop.classList.toggle('visible', window.scrollY + window.innerHeight >= document.documentElement.scrollHeight - 200);
    }, { passive: true });
  </script>
</Layout>