---
import Layout from '../../layouts/Layout.astro';
import { found, cloudinaryUrl } from '../../data/found.js';
import { ArrowUp, ArrowLeft } from 'lucide-astro';
const lang = 'en';
const foundImages = found;
---

<Layout lang={lang} title="Found – Bjørn A. Andersen" description="Personal photography and free time captures by Bjørn A. Andersen.">

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background: #1e2228;
      color: #dde1e7;
      font-family: 'Piazzolla', serif;
    }
    .wrap {
      max-width: 1600px;
      width: 100%;
      margin: 0 auto;
      padding: 2rem 1.5rem 4rem;
    }
    .back {
      display: inline-block;
      color: #ccc;
      text-decoration: none;
      font-size: 0.85rem;
      letter-spacing: 0.05em;
      transition: color 0.2s;
    }
    .back:hover { color: #fff; }

    .back-home {
      position: fixed;
      top: calc(1rem - 4px);
      left: max(1rem, env(safe-area-inset-left, 0px) + 0.5rem);
      color: #ccc;
      text-decoration: none;
      z-index: 100;
      opacity: 0.75;
      transition: opacity 0.3s, transform 0.3s;
      line-height: 1;
    }
    .back-home:hover { opacity: 1; color: #fff; }
    .back-home.hidden {
      opacity: 0;
      pointer-events: none;
      transform: translateY(-0.5rem);
    }

    .scroll-top {
      position: fixed;
      bottom: 1rem;
      left: max(1rem, env(safe-area-inset-left, 0px) + 0.5rem);
      color: #ccc;
      text-decoration: none;
      z-index: 100;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s, transform 0.3s;
      line-height: 1;
      transform: translateY(0.5rem);
    }
    .scroll-top.visible {
      opacity: 0.75;
      pointer-events: auto;
      transform: translateY(0);
    }
    .scroll-top:hover { opacity: 1; color: #fff; }

    .current {
      color: #fff;
      pointer-events: none;
      border-bottom: 1px solid #fff;
    }

    @media (max-width: 700px) {
      .back {
        font-size: 1rem;
        color: #ccc;
      }
    }
    .grid {
      columns: 4;
      gap: 1rem;
      margin-top: 2rem;
      opacity: 0;
      transition: opacity 0.6s ease;
    }

    .grid.ready {
      opacity: 1;
    }
    .grid-item {
      position: relative;
      margin-bottom: 1rem;
      break-inside: avoid;
      border-radius: 6px;
      overflow: hidden;
    }
    .grid-item img {
      width: 100%;
      height: auto;
      display: block;
    }
    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      overflow: hidden;
      clip: rect(0,0,0,0);
      white-space: nowrap;
      border: 0;
    }
    @media (max-width: 700px) {
      .grid { columns: 1; }
    }
    @media (max-width: 400px) {
      .grid { columns: 1; }
    }
  </style>

  <a class="back-home" href="/" aria-label="Back to home"><ArrowLeft size={28} strokeWidth={1.5} /></a>
  <main>
    <div class="wrap">
      <div style="display:flex;justify-content:center;gap:3rem;margin-bottom:2rem;">
        <a class="back" href="/gallery/made">Made</a>
        <span class="back current">Found</span>
      </div>
      <h1 class="sr-only">Found</h1>
      <div class="grid" id="grid">
        {found.map(img => (
          <div class="grid-item">
            <img src={cloudinaryUrl(img.url, { width: 600 })} alt={img.alt} loading="lazy" />
          </div>
        ))}
      </div>
    </div>
  <a class="scroll-top" href="#" onclick="window.scrollTo({top:0,behavior:'smooth'});this.classList.remove('visible');return false;" aria-label="Back to top"><ArrowUp size={28} strokeWidth={1.5} /></a>
    <div style="display:flex;justify-content:center;gap:3rem;padding:2rem 0 3rem;">
      <a class="back" href="/gallery/made">Made</a>
      <span class="back current">Found</span>
    </div>
  </main>

  <script>
    const backHome = document.querySelector('.back-home');
    const scrollTop = document.querySelector('.scroll-top');
    window.addEventListener('scroll', () => {
      backHome.classList.toggle('hidden', window.scrollY > 60);
      scrollTop.classList.toggle('visible', window.scrollY + window.innerHeight >= document.documentElement.scrollHeight - 200);
    }, { passive: true });
  </script>

  <script>
    const grid = document.getElementById('grid');
    const imgs = Array.from(grid.querySelectorAll('img'));
    let loaded = 0;
    const threshold = Math.min(imgs.length, 8);
    const reveal = () => { loaded++; if (loaded >= threshold) requestAnimationFrame(() => grid.classList.add('ready')); };
    imgs.slice(0, threshold).forEach(img => {
      if (img.complete) reveal();
      else { img.addEventListener('load', reveal); img.addEventListener('error', reveal); }
    });
    setTimeout(() => grid.classList.add('ready'), 3000);
  </script>
</Layout>
